# ===========================================
# Moroccan Legal AI Chatbot - Environment Variables
# ===========================================
# Copy this file to .env and adjust values as needed

# ===================
# Ollama Configuration
# ===================
# Host URL for Ollama service
# Local: http://localhost:11434
# Docker: http://ollama:11434
OLLAMA_HOST=http://ollama:11434

# LLM model to use (must be pulled in Ollama)
LLM_MODEL=mistral

# Embedding model for vector search
EMBEDDING_MODEL=nomic-embed-text

# ===================
# RAG Configuration
# ===================
# Path to ChromaDB vector database
CHROMA_PATH=/app/chroma

# Path to PDF documents
DATA_PATH=/app/data/legal_pdfs

# Number of documents to retrieve per query
RETRIEVAL_K=5

# Text chunking settings
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# ===================
# Conversation
# ===================
# Maximum conversation exchanges to keep in memory
MAX_CONVERSATION_HISTORY=5

# ===================
# API Configuration
# ===================
# API server host and port
API_HOST=0.0.0.0
API_PORT=8000

# Allowed CORS origins (JSON array)
CORS_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:80"]

# Debug mode (set to true for development)
DEBUG=false

# ===================
# Application Info
# ===================
APP_NAME=Moroccan Legal AI Chatbot
APP_VERSION=1.0.0
